# ============================================================
# CONFIGURAÇÃO PRONTA PARA PRODUÇÃO - RAILWAY
# ============================================================
# Copie essas variáveis para o painel do Railway e preencha
# seus valores pessoais nos campos com "seu_"
# ============================================================

# ==========================
# BOT TELEGRAM (OBRIGATÓRIO)
# ==========================
BOT_TOKEN=seu_bot_token_do_telegram_aqui
CHAT_ID=seu_chat_id_do_telegram_aqui

# ==========================
# MERCADO LIVRE (RECOMENDADO)
# ==========================
# Habilitar busca de produtos no Mercado Livre
ENABLE_MERCADOLIVRE=1

# Desabilitar AliExpress (deixar com Mercado Livre apenas)
ENABLE_ALIEXPRESS=0

# Termos que o bot vai buscar (separados por vírgula)
# Exemplos para variar: eletrônicos, periféricos, gadgets, etc
TERMOS_BUSCA=mouse gamer,teclado mecanico,fone bluetooth,headset gamer,ssd nvme,memoria ram,carregador turbo,controle bluetooth,fita led rgb,lampada inteligente,camera wifi,air fryer

# Palavras que definem seu nicho (filtro de produtos)
# Só produtos com essas palavras no título serão publicados
NICHO_PALAVRAS=mouse,teclado,fone,headset,ssd,nvme,ram,memoria,carregador,controle,led,smart,wifi,camera,fryer

# País/Site do Mercado Livre (MLB = Brasil)
ML_SITE_ID=MLB

# Quantos produtos buscar por termo (máx 50)
ML_SEARCH_LIMIT=20

# ==========================
# LINK DE AFILIADO (IMPORTANTE)
# ==========================
# Template para transformar URL original em seu link de afiliado
# Opções:
# 1) {url} - Apenas URL original (sem rastreamento)
# 2) {url}?utm_source=telegram&utm_campaign=bot - Com UTM
# 3) https://seu-dominio.com/r?url={url_encoded} - Com redirect seu

ML_AFFILIATE_URL_TEMPLATE={url}?utm_source=telegram&utm_medium=bot&utm_campaign=nichos

# ==========================
# OPCIONAL: IA E ANÁLISE
# ==========================
# Chave da OpenAI (para análise automática de produtos)
# Se não configurar, o bot usa análise padrão sem IA
OPENAI_API_KEY=

# ==========================
# SERVIDOR WEB (PARA OAUTH DO ML)
# ==========================
# Habilitar servidor HTTP para callback OAuth do Mercado Livre
WEB_SERVER_ENABLED=1

# Host (deixar como 0.0.0.0 para Railway)
WEB_SERVER_HOST=0.0.0.0

# Porta (Railway injeta PORT automaticamente, não precisa configurar)
# WEB_SERVER_PORT será lido de PORT ou padrão 8080

# ==========================
# OAUTH MERCADO LIVRE (OPCIONAL)
# ==========================
# Se quiser capturar o token OAuth automaticamente, configure:
# 1) Crie um app em https://developers.mercadolibre.com.br/
# 2) Configure as 3 variáveis abaixo
# 3) Aponte ML_REDIRECT_URI para seu domínio no Railway

# ID da sua app no Mercado Livre
ML_APP_ID=

# Secret da sua app
ML_CLIENT_SECRET=

# URL de redirect (substitua seu-dominio.railway.app)
# Exemplo: https://seu-dominio.railway.app/mercadolivre/callback
ML_REDIRECT_URI=

# ==========================
# AGENDADOR DE RELATÓRIO (OPCIONAL)
# ==========================
# Email para receber relatório diário
REPORT_TARGET=seu_email@example.com

# Hora do relatório (HH:MM)
DAILY_REPORT_HOUR=08:00

# Chat ID para notificações do admin (opcional)
ADMIN_CHAT_ID=

# ==========================
# CONFIGURAÇÃO TÉCNICA
# ==========================
# Intervalo entre buscas (segundos)
INTERVALO=300

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Logo personalizado (caminho local ou URL)
LOGO=

# ==========================
# ENDPOINTS DO MERCADO LIVRE
# ==========================
# Não precisa alterar (apenas se usar ML com OAuth)
ML_CODE_FILE=mercadolivre_code.jsonl
ML_TOKEN_FILE=mercadolivre_token.json

# ==========================
# INSTRUÇÕES PARA RAILWAY
# ==========================
# 1. Crie um novo projeto no Railway
# 2. Conecte este repositório GitHub
# 3. Adicione as variáveis de ambiente acima no painel do Railway
# 4. Preencha BOT_TOKEN e CHAT_ID (obrigatório)
# 5. Configure ML_AFFILIATE_URL_TEMPLATE com seu link
# 6. Deploy será automático
#
# Variáveis mínimas obrigatórias:
# - BOT_TOKEN
# - CHAT_ID
# - ENABLE_MERCADOLIVRE (se quiser usar ML)
# - ML_AFFILIATE_URL_TEMPLATE (seu link de afiliado)
#
# Status do bot:
# - Logs em tempo real: Railway > Deployments > View Logs
# - Health check: GET /health
# - Callback OAuth: GET /mercadolivre/callback
