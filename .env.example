# Preencha os valores abaixo antes de rodar o bot
BOT_TOKEN=
CHAT_ID=
ALI_KEY=
ALI_SECRET=
TRACKING_ID=
ENABLE_ALIEXPRESS=1
ENABLE_MERCADOLIVRE=1
TERMOS_BUSCA=mouse gamer,teclado mecanico,fone bluetooth,headset gamer,ssd nvme,memoria ram ddr4,memoria ram ddr5,carregador turbo,controle bluetooth,fita led rgb,lampada inteligente,camera wifi,air fryer,cafeteira
NICHO_PALAVRAS=mouse,teclado,fone,headset,ssd,nvme,ram,memoria,carregador,controle,led,smart,wifi,camera,air fryer,cafeteira

# Opcional
ENABLE_OPENAI=0
OPENAI_API_KEY=
ADMIN_CHAT_ID=
DAILY_REPORT_HOUR=08:00
REPORT_TARGET=
INTERVALO=300
LOGO=path/to/logo.png

# Servidor web para receber o code OAuth (Mercado Livre)
WEB_SERVER_ENABLED=1
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080
ML_CODE_FILE=mercadolivre_code.jsonl
ML_TOKEN_FILE=mercadolivre_token.json

# OAuth Mercado Livre (para trocar o code por token automaticamente)
ML_APP_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://SEU_DOMINIO_OU_IP:8080/mercadolivre/callback

# Busca e link afiliado do Mercado Livre
ML_SITE_ID=MLB
ML_SEARCH_LIMIT=20
# Exemplo para redirecionar ao seu link de afiliado:
# ML_AFFILIATE_URL_TEMPLATE=https://seu-dominio.com/r?destino={url_encoded}
ML_AFFILIATE_URL_TEMPLATE={url}
